   "source": [
    "import numpy as np\n",
    "\n",
    "# Creating a NumPy array from a Python list\n",
    "data = [10, 20, 30, 40, 50]\n",
    "arr = np.array(data)\n",
    "\n",
    "# Display array\n",
    "print(\"Array:\", arr)\n",
    "\n",
    "# Display shape and data type\n",
    "print(\"Shape:\", arr.shape)\n",
    "print(\"Data Type:\", arr.dtype)"
   ]
