   "source": [
    "import numpy as np\n",
    "\n",
    "# Create array from 1 to 12\n",
    "arr = np.arange(1, 13)\n",
    "\n",
    "# Reshape to 3x4\n",
    "reshaped_arr = arr.reshape(3, 4)\n",
    "\n",
    "print(\"Original Array:\", arr)\n",
    "print(\"Original Shape:\", arr.shape)\n",
    "\n",
    "print(\"\\nReshaped Array:\")\n",
    "print(reshaped_arr)\n",
    "print(\"Reshaped Shape:\", reshaped_arr.shape)"
   ]
