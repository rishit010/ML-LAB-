    "import numpy as np\n",
    "\n",
    "# Create array of 10 random integers between 1 and 100\n",
    "arr = np.random.randint(1, 101, 10)\n",
    "\n",
    "print(\"Array:\", arr)\n",
    "print(\"Minimum:\", arr.min())\n",
    "print(\"Maximum:\", arr.max())\n",
    "print(\"Mean:\", arr.mean())\n",
    "print(\"Sum:\", arr.sum())"
