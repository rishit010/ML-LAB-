   "source": [
    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"data.csv\")\n",
    "\n",
    "df[\"Gender\"] = df[\"Gender\"].replace({\n",
    "    \"F\": \"Female\",\n",
    "    \"M\": \"Male\",\n",
    "    \"male\": \"Male\",\n",
    "    \"female\": \"Female\"\n",
    "})\n",
    "\n",
    "print(\"Corrected gender column:\")\n",
    "print(df[\"Gender\"])"
   ]
  }
