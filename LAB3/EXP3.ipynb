    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"StudentsPerformance.csv\")\n",
    "\n",
    "scores = df[[\"math score\", \"reading score\", \"writing score\"]]\n",
    "\n",
    "print(\"Correlation Matrix:\")\n",
    "print(scores.corr())\n",
    "\n",
    "print(\"\\nCovariance Matrix:\")\n",
    "print(scores.cov())"
   ]
  }
